# =============================================================================
# QueryBridge Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
#
# If no QUERYBRIDGE_DSN is set, the bundled Chinook demo database is used.
# =============================================================================

# ---------------------------------------------------------------------------
# Primary Database (optional — demo DB used if omitted)
# ---------------------------------------------------------------------------
# QUERYBRIDGE_DSN=postgresql+asyncpg://user:pass@host:5432/mydb
# QUERYBRIDGE_DEFAULT_NAME=My Database

# ---------------------------------------------------------------------------
# LLM Provider (required)
# ---------------------------------------------------------------------------
QUERYBRIDGE_PROVIDER=openai
QUERYBRIDGE_API_KEY=sk-your-api-key-here
# QUERYBRIDGE_BASE_URL=https://api.openai.com/v1
QUERYBRIDGE_MODEL=gpt-4o

# If your LLM gateway uses a custom auth header instead of Authorization,
# set the header name here (the API key above will be sent as its value).
# QUERYBRIDGE_CUSTOM_AUTH_HEADER=Ocp-Apim-Subscription-Key

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
